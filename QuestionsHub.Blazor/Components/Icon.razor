@*
    Reusable SVG icon component that references the centralized icon sprite.
    Usage: <Icon Name="search" Class="text-muted me-2" Size="20" />
*@

@{
    var symbolId = GetSymbolId(Name);
    var cssClass = string.IsNullOrEmpty(Class) ? "icon" : $"icon {Class}";
    var spriteUrl = Assets["icons.svg"];
}

@if (!string.IsNullOrEmpty(Title))
{
    <svg class="@cssClass" width="@Size" height="@Size" role="img" focusable="false">
        <title>@Title</title>
        <use href="@($"{spriteUrl}#{symbolId}")"></use>
    </svg>
}
else
{
    <svg class="@cssClass" width="@Size" height="@Size" aria-hidden="true" focusable="false">
        <use href="@($"{spriteUrl}#{symbolId}")"></use>
    </svg>
}

@code {
    /// <summary>
    /// Icon name. Supported values: check, link, drag, search, close, group, shield-exclamation, person-plus, person-minus,
    /// plus, exclamation-triangle, check-circle, x-circle, envelope-check, pencil, info-circle, question-circle,
    /// collection, external-link, upload, arrow-repeat, box, list-ul, arrow-left, exclamation-circle, and more.
    /// </summary>
    [Parameter, EditorRequired]
    public required string Name { get; set; }

    /// <summary>
    /// Additional CSS classes to add to the SVG element (e.g., Bootstrap utilities like text-danger, me-2).
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Width and height in pixels. Default is 16.
    /// </summary>
    [Parameter]
    public int Size { get; set; } = 16;

    /// <summary>
    /// Optional accessible title. If provided, the icon will have role="img" instead of aria-hidden="true".
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    private static string GetSymbolId(string name)
    {
        return name.ToLowerInvariant() switch
        {
            "check" or "copied" => "i-check",
            "link" => "i-link",
            "drag" or "handle" or "grip" => "i-drag",
            "search" => "i-search",
            "close" or "x" => "i-close",
            "group" or "users" or "people" => "i-group",
            "shield-exclamation" or "shield" => "i-shield-exclamation",
            "person-plus" or "user-plus" => "i-person-plus",
            "person-minus" or "user-minus" => "i-person-minus",
            "chevron-left" => "i-chevron-left",
            "chevron-right" or "arrow-right" => "i-chevron-right",
            "chevron-double-left" or "chevrons-left" => "i-chevron-double-left",
            "chevron-double-right" or "chevrons-right" => "i-chevron-double-right",
            "chevron-down" or "expand" => "i-chevron-down",
            "chevron-up" or "collapse" => "i-chevron-up",
            "sun" or "light" => "i-sun",
            "moon" or "dark" => "i-moon",
            "sort-up" or "sort-asc" or "arrow-up" => "i-sort-up",
            "sort-down" or "sort-desc" or "arrow-down" => "i-sort-down",
            "funnel" or "filter" => "i-funnel",
            "chevron-up-down" or "sort" or "selector" => "i-chevron-up-down",
            "download" or "export" => "i-download",
            "eye" or "show" or "visible" => "i-eye",
            "eye-slash" or "hide" or "hidden" => "i-eye-slash",
            "person-circle" or "user-circle" or "avatar" => "i-person-circle",
            "home" or "house" => "i-home",
            "folder" or "packages" => "i-folder",
            "person-badge" or "editor-badge" => "i-person-badge",
            "person-gear" or "user-settings" => "i-person-gear",
            "menu" or "hamburger" or "bars" => "i-menu",
            "trash" or "delete" => "i-trash",
            "plus" or "add" => "i-plus",
            "exclamation-triangle" or "warning" => "i-exclamation-triangle",
            "check-circle" or "success" => "i-check-circle",
            "x-circle" or "error" => "i-x-circle",
            "envelope-check" or "email-confirmed" => "i-envelope-check",
            "pencil" or "edit" => "i-pencil",
            "info-circle" or "info" => "i-info-circle",
            "question-circle" or "help" => "i-question-circle",
            "collection" => "i-collection",
            "external-link" or "box-arrow-up-right" => "i-external-link",
            "upload" => "i-upload",
            "arrow-repeat" or "sync" or "refresh" => "i-arrow-repeat",
            "box" or "package" => "i-box",
            "list-ul" or "list" => "i-list-ul",
            "arrow-left" or "back" => "i-arrow-left",
            "exclamation-circle" => "i-exclamation-circle",
            _ => $"i-{name.ToLowerInvariant()}"
        };
    }
}
